{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.learn-system.com/progress.schema.json",
  "title": "Learning Progress Schema",
  "description": "Schema for learning progress data structure",
  "type": "object",
  "required": ["version", "courses"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "active_goal_id": {
      "type": ["string", "null"],
      "description": "ID of the currently active learning goal",
      "default": null
    },
    "courses": {
      "type": "object",
      "description": "Map of course name to progress details",
      "additionalProperties": {
        "$ref": "#/definitions/course_progress"
      }
    }
  },
  "definitions": {
    "course_progress": {
      "type": "object",
      "required": ["name", "priority", "mode", "overall_progress", "modules"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the course",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"],
          "description": "Priority level",
          "default": "P1"
        },
        "mode": {
          "type": "string",
          "enum": ["quick", "full", "both"],
          "description": "Learning mode",
          "default": "full"
        },
        "started_at": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Start date (YYYY-MM-DD)",
          "default": null
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Completion date (YYYY-MM-DD)",
          "default": null
        },
        "current_module": {
          "type": ["string", "null"],
          "description": "Currently learning module",
          "default": null
        },
        "overall_progress": {
          "type": "integer",
          "description": "Overall progress percentage (0-100)",
          "minimum": 0,
          "maximum": 100,
          "default": 0
        },
        "modules": {
          "type": "object",
          "description": "Map of module name to module progress",
          "additionalProperties": {
            "$ref": "#/definitions/module_progress"
          }
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata",
          "properties": {
            "total_time_spent": {
              "type": "integer",
              "description": "Total time spent in minutes",
              "default": 0
            },
            "last_updated": {
              "type": "string",
              "format": "date-time",
              "description": "Last update timestamp"
            }
          }
        }
      }
    },
    "module_progress": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "in_progress", "completed", "skipped"],
          "description": "Module status",
          "default": "not_started"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Completion date (YYYY-MM-DD)",
          "default": null
        },
        "notes": {
          "type": "string",
          "description": "User notes for the module",
          "default": ""
        },
        "resources_visited": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of resource URLs visited",
          "default": []
        }
      }
    }
  }
}
